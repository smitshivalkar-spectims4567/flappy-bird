<!DOCTYPE html>
<html>
<head>
    <title>Flappy Bird</title>
    <style>
        body { margin: 0; overflow: hidden; background: #87CEEB; font-family: sans-serif; }
        canvas { display: block; margin: 20px auto; background: #87CEEB; border: 2px solid #333; }
        #score { text-align: center; font-size: 24px; font-weight: bold; color: #333; }
        #restart { display: none; margin: 10px auto; padding: 10px 20px; font-size: 18px; cursor: pointer; }
    </style>
</head>
<body>
    <div id="score">Score: 0</div>
    <canvas id="game" width="500" height="500"></canvas>
    <button id="restart">Restart</button>
    <script>
        const canvas = document.getElementById('game');
        const ctx = canvas.getContext('2d');
        const scoreEl = document.getElementById('score');
        const restartBtn = document.getElementById('restart');

        const GRAVITY = 0.333;
        const JUMP = -6.67;
        const PIPE_WIDTH = 75;
        const PIPE_GAP = 134;
        const PIPE_SPEED = 3.75;

        let bird = { x: 100, y: 250, vy: 0, size: 17 };
        let pipes = [];
        let score = 0;
        let gameOver = false;

        function reset() {
            bird = { x: 100, y: 250, vy: 0, size: 17 };
            pipes = [];
            score = 0;
            gameOver = false;
            scoreEl.textContent = 'Score: 0';
            restartBtn.style.display = 'none';
        }

        function spawnPipe() {
            const margin = 42;
            const gapY = Math.random() * (canvas.height - PIPE_GAP - 2 * margin) + margin;
            pipes.push({ x: canvas.width, gapY, passed: false });
        }

        function update() {
            if (gameOver) return;

            bird.vy += GRAVITY;
            bird.y += bird.vy;

            if (bird.y < 0 || bird.y + bird.size > canvas.height) endGame();

            for (let pipe of pipes) {
                pipe.x -= PIPE_SPEED;

                const hitX = bird.x + bird.size > pipe.x && bird.x < pipe.x + PIPE_WIDTH;
                const hitY = bird.y < pipe.gapY || bird.y + bird.size > pipe.gapY + PIPE_GAP;
                if (hitX && hitY) endGame();

                if (!pipe.passed && pipe.x + PIPE_WIDTH < bird.x) {
                    pipe.passed = true;
                    score++;
                    scoreEl.textContent = 'Score: ' + score;
                }
            }

            if (pipes.length === 0 || pipes[pipes.length - 1].x < canvas.width - 250) {
                spawnPipe();
            }
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            ctx.fillStyle = '#FFD700';
            ctx.fillRect(bird.x, bird.y, bird.size, bird.size);

            ctx.fillStyle = '#228B22';
            for (let pipe of pipes) {
                ctx.fillRect(pipe.x, 0, PIPE_WIDTH, pipe.gapY);
                ctx.fillRect(pipe.x, pipe.gapY + PIPE_GAP, PIPE_WIDTH, canvas.height - pipe.gapY - PIPE_GAP);
            }

            ctx.fillStyle = '#333';
            ctx.font = '24px sans-serif';
            ctx.fillText('Score: ' + score, 20, 40);
        }

        function endGame() {
            gameOver = true;
            restartBtn.style.display = 'block';
        }

        function loop() {
            update();
            draw();
            requestAnimationFrame(loop);
        }

        document.addEventListener('keydown', e => {
            if (e.code === 'Space') {
                if (gameOver) reset();
                else bird.vy = JUMP;
            }
        });

        canvas.addEventListener('click', () => {
            if (gameOver) reset();
            else bird.vy = JUMP;
        });

        restartBtn.addEventListener('click', reset);

        spawnPipe();
        loop();
    </script>
</body>
</html>
